<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مسابقة أعلام السنة | جمعية سنن</title>
    <style>
        :root {
            --primary: #2A3F46;
            --secondary: #7D7168;
            --bg-color: #F3EFE9;
            --white: #FFFFFF;
            --accent: #8C847D;
        }

        @font-face {
            font-family: 'Handicrafts';
            src: url('fonts/TheYearofHandicrafts-Bold.otf') format('opentype');
            font-weight: bold;
        }

        body {
            font-family: 'Handicrafts', Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--primary);
            margin: 0;
            padding: 0;
            line-height: 1.6;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
            flex: 1;
            display: flex;
            flex-direction: column;
            width: 100%;
            box-sizing: border-box;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            border-bottom: 2px solid var(--secondary);
            margin-bottom: 40px;
        }

        .logo-main { max-height: 100px; object-fit: contain; width: 45%; }
        .logo-contest { max-height: 100px; object-fit: contain; width: 45%; }

        .card {
            background: var(--white);
            padding: 50px 30px;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            margin: auto 0; /* لتوسيط البطاقة عمودياً في المساحة المتبقية */
            border: 1px solid rgba(125, 113, 104, 0.1);
            text-align: center;
        }

        h2 { color: var(--primary); margin-bottom: 15px; font-size: 32px; }
        p { color: var(--secondary); font-size: 18px; margin-bottom: 40px; font-weight: bold; }

        .submit-btn {
            background-color: var(--primary);
            color: var(--white);
            border: none;
            width: 100%;
            padding: 20px;
            border-radius: 12px;
            font-size: 22px;
            font-family: 'Handicrafts', sans-serif;
            cursor: pointer;
            transition: 0.3s;
            box-shadow: 0 4px 15px rgba(42, 63, 70, 0.2);
            display: block;
            text-align: center;
            text-decoration: none;
            box-sizing: border-box;
        }

        .submit-btn:hover { 
            background-color: #1e2e33; 
            transform: translateY(-3px); 
            box-shadow: 0 6px 20px rgba(42, 63, 70, 0.3);
        }

        footer { text-align: center; margin-top: auto; padding-top: 40px; padding-bottom: 30px; }
        footer p { color: var(--accent); font-size: 14px; margin-bottom: 15px; }

        .sponsors {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 30px;
            flex-wrap: wrap;
        }

        .sponsors img { height: 90px; object-fit: contain; filter: grayscale(20%); transition: 0.3s; }
        .sponsors img:hover { filter: grayscale(0%); }

        .status-icon { font-size: 70px; margin-bottom: 20px; }
    </style>
</head>
<body>

<div class="container">
    <!-- القسم العلوي: الشعارات -->
    <header>
        <img src="images/logo-sunnan.png" class="logo-main" alt="جمعية سنن">
        <img src="images/logo-contest.png" class="logo-contest" alt="مسابقة أعلام السنة">
    </header>

    <!-- القسم الأوسط: رسالة الإغلاق -->
    <div class="card">
        <div class="status-icon">⏳</div>
        <h2>انتهى وقت المشاركة</h2>
        <p>نشكر لكم تفاعلكم.. ونتمنى التوفيق للجميع في السحب</p>
        
        <!-- زر الانتقال إلى العجلة -->
        <a href="https://sunnan-quizz.vercel.app/wheell.html" class="submit-btn">
            للانتقال إلى صفحة السحب: اضغط هنا 🎡
        </a>
    </div>

    <!-- القسم السفلي: الرعاة -->
    <footer>
        <p>الـــرعاة المشاركين</p>
        <div class="sponsors">
            <img src="images/sponsor1.png" alt="رياش">
            <img src="images/sponsor2.png" alt="نسيل">
        </div>
    </footer>
</div>

</body>
</html>
